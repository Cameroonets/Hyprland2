{
  "position": "top",
    "margin-top" : 2,
    "margin-left": 2,
    "margin-right": 2,
    "height" : 29,
    "modules-left": [
      "power-profiles-daemon",
      "custom/swaync",
      "tray",
      "clock",
      "hyprland/window"
    ],
    "modules-center": [
	"hyprland/workspaces"
    ],
    "modules-right": [
    "hyprland/language",
    "pulseaudio",
    "battery",
    "network",
    "custom/terminal",
    "custom/thunar",
    "custom/browser",
    "custom/exit"
    ],
       "hyprland/window": {
      "format": "{}",
      "max-length": 35,
      "rewrite": {
        "": "Hyprland"
      },
      "separate-outputs": true
    },
    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "active": "яЖТ",
	"urgent": "яБк",
	"default": "яДМ",
      },
      "on-click": "activate",
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 5,
        "HDMI-A-1": 5
      },
    "tray": {
      "icon-size": 10,
      "spacing": 10
      },
    },
    "clock": {
      "format": "{:%I:%M %p}",
      "tooltip": false,
      "format-alt": "{:%Y/%m/%d}"
    },
    "cpu": {
      "format": " {usage}%",
      "tooltip": false
    },
    "memory": {
      "format": "{}% "
    },
    "network": {
      "format-wifi": "яЗл  {signalStrength}%",
      "format-ethernet": "{cidr} яЮЦ",
      "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
      "format-linked": "{ifname} (No IP) яЮЦ",
      "format-disconnected": " тЪа ",
      "on-click": "kitty -e nmtui"
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}  {capacity}%",
      "format-full": "{icon}  {capacity}%",
      "format-charging": "яЧз  {capacity}%",
      "format-plugged": "яЗж  {capacity}%",
      "format-alt": "{time} {icon}",
      "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "hyprland/language": {
    "format": "{short}",
    "rewrite": {
        "Russian": "RU",
        "English (US)": "ENG"
    }
    },
    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
      "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
      "format-muted": "яЪй {format_source}",
      "format-icons": {
        "headphone": "яАе",
        "hands-free": "яЦР",
        "headset": "яЦР",
        "phone": "яВХ",
        "portable": "яВХ",
        "car": "яЖ╣",
        "default": ["яАж", "яАз", "яАи"]
      },
      "on-click": "pavucontrol"
    },
    "hyprland/window": {
        "format": {},
        "max-length": 12,
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}",
        "format-icons": {
            "performance": "ю╜╢",
            "balanced": "яЙО ",
            "power-saver": "ґ░ВД"
        }
    },
    "custom/exit": {
        "format": "яАС",
        "on-click": "wlogout",
        "tooltip": false
    },
    "custom/terminal": {
        "format": "яТ╡",
        "on-click": "kitty",
        "tooltip": false
    },
    "custom/browser": {
        "format": "ґ░И╣",
        "on-click": "firefox",
        "tooltip": false
    },
    "custom/thunar": {
        "format": "яУФ",
        "on-click": "thunar",
        "tooltip": false
    },
    "custom/swaync": {
        "format": "яГ│",
	"on-click": "swaync-client -t -sw",
        "tooltip": false
    },
}
